<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dynamic_blog_posts_snippet_registry"
              inherit_id="website.snippets"
              name="Dynamic Blog Posts Snippet Registry">
        <xpath expr="//snippets[@id='snippet_groups']/t[@snippet-group][last()]" position="after">
            <t snippet="odoo_dynamic_blog_snippet.dynamic_blog_posts_snippet"
               string="Dynamic Blog Posts"
               group="content"/>
        </xpath>
    </template>
</odoo>
