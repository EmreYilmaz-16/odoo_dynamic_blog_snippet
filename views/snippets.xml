<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="dynamic_blog_posts_snippet_registry"
              inherit_id="website.snippets"
              name="Dynamic Blog Posts Snippet Registry">
        <xpath expr="//snippets[@id='snippet_content']" position="inside">
            <t t-snippet="odoo_dynamic_blog_snippet.dynamic_blog_posts_snippet"
               string="Dynamic Blog Posts"
               group="content"
               t-thumbnail="/website/static/src/img/snippets_thumbs/s_text_highlight.svg"/>
        </xpath>
    </template>
</odoo>
